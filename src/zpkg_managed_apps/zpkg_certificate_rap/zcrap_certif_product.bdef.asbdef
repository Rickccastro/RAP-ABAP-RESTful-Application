projection;
strict ( 2 );
use draft;

define behavior for ZCRAP_CERTIF_PRODUCT alias Certificate
{
  use create;
  use update;
  use delete;

  use association _Stats { create; with draft; }

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use action NewVersion;
  use action ActiveVersion;
  use action InactiveVersion;

}

define behavior for ZCRAP_CERTIF_ST_PRODUCT alias Certificate_ST
{
  use delete;

  use association _Certif;
}